# Controls if logger outputs go to disk (True) or stdout (false)
WRITE_LOGS=True

# CORS Settings
ALLOWED_ORIGINS=http://localhost:5173
ALLOWED_METHODS=*
ALLOWED_HEADERS=*
ALLOWED_CREDENTIALS=False

# EXPA OAuth
EXPA_CLIENT_ID=
EXPA_CLIENT_SECRET=
EXPA_REDIRECT_URI=
EXPA_TOKEN_URL=https://auth.aiesec.org/oauth/token
AIESEC_GRAPHQL_ENDPOINT=https://gis-api.aiesec.org/graphql
# Optional; set if your app requires scopes (ask PM / dev portal). Example: openid
# EXPA_OAUTH_SCOPE=

# Pinecone client
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# Supabase client
SUPABASE_URL=
SUPABASE_KEY=

# Gemini client
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
